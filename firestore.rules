rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidCategory(data) {
        return data.keys().hasAll(['name']) && 
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               (!data.keys().hasAny(['order']) || data.order is number);
      }
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'categoryId']) &&
               data.name is string && data.name.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.categoryId is string &&
               (!data.keys().hasAny(['description']) || data.description is string) &&
               (!data.keys().hasAny(['image']) || data.image is string) &&
               (!data.keys().hasAny(['isAvailable']) || data.isAvailable is bool);
      }
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read, update, delete: if isAdmin();

      function isValidOrder(data) {
        return data.keys().hasAll(['customerName', 'items', 'totalPrice', 'status', 'createdAt']) &&
               data.customerName is string && data.customerName.size() <= 100 &&
               data.items is list && data.items.size() > 0 &&
               data.totalPrice is number && data.totalPrice >= 0 &&
               data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
               data.createdAt == request.time;
      }
    }

    // --- Admins ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow create: if isSignedIn() && request.auth.uid == adminId;
      allow update, delete: if false; 
    }
  }
}
